# Third-party reference implementation — cloned study material, NOT part of this project.
# Our analysis lives in reference/ANALYSIS.md (tracked); the cloned source is ignored.
/reference/open-claude-in-chrome/

# Rust build output
/target/

# Packaged extension zip (scripts/package-extension.ps1 output)
/dist/

# Extension signing key (private). The manifest "key" (public) pins a stable dev extension id;
# this private half is only needed to pack a .crx and must never be committed. It must NOT live
# inside extension/ -- Chrome loads that whole dir and warns about a bundled key file.
.dev-key.pem

# OS / editor cruft
.DS_Store
Thumbs.db
/tests/e2e/node_modules/

# Stray observability files, in case a debug run is ever pointed at the repo (they normally live
# under the log dir; see src/observability.rs). Never source.
/debug-state-*.json
/debug-events-*.jsonl

# Local Claude Code settings (machine-specific paths, personal permission grants). Not shared.
/.claude/

# Founder-personal stash (entity/legal/insurance planning, personal to-dos, account notes).
# Deliberately untracked: never pushed, never published. Backed up only by whatever covers
# the working tree (NAS replica), not by git.
/private/
/saps

# Machine-local dev state and working notes (engine/install state, session handoffs).
# The convention is documented in local/README.md, which stays tracked; everything else
# in local/ is this machine's business only.
/local/*
!/local/README.md
