{
  "manifest_version": 3,
  "name": "Browser MCP",
  "version": "0.1.0",
  "description": "Governed browser automation over your own authenticated session, for AI agents.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": [
    "tabs",
    "debugger",
    "scripting",
    "nativeMessaging",
    "tabGroups",
    "windows",
    "storage",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": { "default_title": "Browser MCP", "default_popup": "popup.html" },
  "commands": {
    "toggle-hold": {
      "suggested_key": { "default": "Alt+Shift+P" },
      "description": "Pause or resume agent browsing (take the wheel)"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["agent-visual-indicator.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
